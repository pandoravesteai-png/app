{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and credit balance",
      "type": "object",
      "properties": {
        "credits": {
          "type": "integer",
          "description": "Number of credits available for the user"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user account was created"
        },
        "name": {
          "type": "string",
          "description": "User's full name"
        },
        "email": {
          "type": "string",
          "description": "User's email address"
        },
        "lastPlan": {
          "type": "string",
          "description": "The last credit plan purchased by the user"
        },
        "streak": {
          "type": "integer",
          "description": "Consecutive days using the app"
        },
        "styleProfile": {
          "type": "string",
          "description": "User's detected fashion style (from quiz)"
        },
        "styleTags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tags of styles/items the user has tried on"
        },
        "role": {
          "type": "string",
          "description": "User role (admin or user)"
        },
        "subscriptionTier": {
          "type": "string",
          "enum": ["basic", "premium"],
          "description": "Current subscription tier (basic=19.90, premium=29.90)"
        },
        "subscriptionExpiresAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the current premium subscription expires"
        },
        "subscriptionStartDate": {
          "type": "string",
          "format": "date-time",
          "description": "When the current subscription started"
        },
        "creditsReleased": {
          "type": "integer",
          "description": "Number of credits already released to the user"
        },
        "totalPhotosGenerated": {
          "type": "integer",
          "description": "Total number of photos generated by the user"
        },
        "dailyUsage": {
          "type": "object",
          "properties": {
            "date": { "type": "string" },
            "count": { "type": "integer" }
          },
          "description": "Daily usage tracking for rewards"
        },
        "lastRouletteSpin": {
          "type": "string",
          "format": "date-time",
          "description": "Last time the user spun the roulette"
        },
        "rechargeCount": {
          "type": "integer",
          "description": "Number of times the user has recharged"
        },
        "badge": {
          "type": "string",
          "enum": ["bronze", "silver", "gold", "diamond"],
          "description": "User's current achievement badge"
        },
        "pendingCredits": {
          "type": "integer",
          "description": "Credits to be released over time"
        },
        "loyaltyBonusClaimed": {
          "type": "boolean",
          "description": "Whether the user has claimed the loyalty bonus for the second recharge"
        }
      },
      "required": ["credits", "createdAt", "email"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction (revenue)",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "amount": { "type": "number" },
        "credits": { "type": "integer" },
        "plan": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "orderId": { "type": "string" }
      },
      "required": ["userId", "amount", "date"]
    },
    "ApiUsage": {
      "title": "ApiUsage",
      "description": "Cost of API generation",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "description": "try-on or 360" },
        "cost": { "type": "number", "description": "Cost in USD or BRL" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "cost", "date"]
    },
    "Avaliacao": {
      "title": "Avaliacao",
      "description": "User feedback and rating",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "rating": { "type": "integer" },
        "comment": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "rating", "date"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User documents stored by their unique ID"
    },
    "/users/{userId}/history/{historyId}": {
      "schema": "object",
      "description": "User generation history"
    },
    "/avaliacoes/{avaliacaoId}": {
      "schema": "Avaliacao",
      "description": "Global collection of user ratings"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Global collection of all revenue transactions"
    },
    "/api_usage/{usageId}": {
      "schema": "ApiUsage",
      "description": "Global collection of all API costs"
    }
  }
}
