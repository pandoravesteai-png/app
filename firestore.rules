rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && (
        request.auth.uid == userId || 
        (request.auth.token.email != null && request.auth.token.email.lower() == userId.lower())
      );
    }

    match /users/{userId} {
      // Allow read even if document doesn't exist, as long as the ID matches the user's identity
      // This is crucial for getDoc() calls on new users
      allow read: if isOwner(userId) || (isAuthenticated() && resource == null && request.auth.token.email.lower() == userId.lower());
      
      // Allow create if the user is the owner (by UID or email)
      // We also check that the data being written matches the user's email
      allow create: if isOwner(userId) || (isAuthenticated() && request.resource.data.email.lower() == request.auth.token.email.lower());
      
      // Allow update if the user is the owner
      allow update: if isOwner(userId);
      
      // Allow delete if the user is the owner
      allow delete: if isOwner(userId);
      
      match /{subcollection}/{docId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    match /avaliacoes/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }
    
    match /historico/{docId} {
      allow read, write: if isAuthenticated();
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
