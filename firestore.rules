rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && (request.auth.uid == userId || (request.auth.token.email != null && request.auth.token.email.lower() == userId.lower()));
    }

    match /users/{userId} {
      // Allow full access to own document
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      
      // Allow listing documents if filtering by own email
      allow list: if isAuthenticated() && 
                    request.auth.token.email != null && 
                    request.query.filters.email == request.auth.token.email.lower();

      // Allow reading and deleting orphaned documents with the same email
      allow get, delete: if isAuthenticated() && 
                            request.auth.token.email != null && 
                            (resource.data.get('email', '').lower() == request.auth.token.email.lower());
      
      match /{subcollection}/{docId} {
        allow read, write: if isAuthenticated() && (
          request.auth.uid == userId || 
          (request.auth.token.email != null && get(/databases/$(database)/documents/users/$(userId)).data.get('email', '').lower() == request.auth.token.email.lower())
        );
      }
    }

    match /avaliacoes/{docId} {
      allow read, create: if isAuthenticated();
      allow update, delete: if false;
    }

    match /historico/{docId} {
      allow read, write: if isAuthenticated();
    }
  }
}
